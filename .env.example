# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string

# ── Postgres (Supabase) ───────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → Database → Connection string
DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── Neo4j (Sandbox / AuraDB) ──────────────────────────────────────────────────
# Sandbox: sandbox.neo4j.com → Connection details (bolt://<ip>, expires in ~10 days)
# AuraDB:  neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# ── Demo mode ─────────────────────────────────────────────────────────────────
# true  → synthetic forecasters active, demo data loaded (Bio Africa presentation)
# false → real users only, no synthetic data
DEMO_MODE=true
