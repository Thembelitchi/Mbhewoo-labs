# Mbhewoo Labs - Environment Configurations

# Application Environment: dev or prod
ENVIRONMENT=dev

# FastAPI Secret Key for session signing, cryptographic tokens, etc.
# Generate a secure random string for production
SECRET_KEY=dev_secret_key_change_me_in_production_1234567890

# PostgreSQL Settings (Supabase Connection String)
# Example: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mbhewoo_labs

# Neo4j Settings (Neo4j AuraDB Connection)
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
